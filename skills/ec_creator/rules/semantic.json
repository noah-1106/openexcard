{
  "version": "1.0.0",
  "description": "Semantic validation rules for EC files",
  "patterns": [
    {
      "name": "network_operations",
      "keywords": [
        "upload",
        "post",
        "send",
        "api",
        "http",
        "request",
        "fetch",
        "download"
      ],
      "required_dependencies": [
        "network",
        "curl",
        "wget",
        "api",
        "http"
      ],
      "warning_message": "Network operations detected but no network skill declared in dependencies"
    },
    {
      "name": "file_operations",
      "keywords": [
        "read",
        "write",
        "save",
        "load",
        "open",
        "create file"
      ],
      "required_dependencies": [
        "file",
        "fs",
        "read",
        "write"
      ],
      "level": "info"
    },
    {
      "name": "error_handling",
      "keywords": [
        "error",
        "fail",
        "retry",
        "exception",
        "catch",
        "if.*fail",
        "on error",
        "handle error"
      ],
      "minimum_count": 1,
      "warning_message": "No explicit error handling found - add retry logic or failure recovery"
    },
    {
      "name": "input_validation",
      "keywords": [
        "check",
        "validate",
        "verify",
        "if.*exist",
        "ensure",
        "confirm"
      ],
      "minimum_count": 1,
      "suggestion": "Add input validation steps to prevent downstream errors"
    },
    {
      "name": "state_management",
      "keywords": [
        "state",
        "status",
        "update",
        "mark",
        "record"
      ],
      "recommended": true,
      "suggestion": "Consider recording execution state for resume capability"
    }
  ],
  "quality_gates": {
    "minimum_steps": 3,
    "maximum_steps": 15,
    "requires_io_definition": true,
    "requires_error_handling": true
  }
}
