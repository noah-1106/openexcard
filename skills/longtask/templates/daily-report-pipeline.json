{
  "template_id": "daily-report-pipeline",
  "name": "每日调研报告发布流水线",
  "description": "自动生成调研报告并发布到社交平台",
  "version": "1.0",
  "steps": [
    {
      "step_id": 1,
      "name": "生成调研报告",
      "description": "调用路路生成每日调研数据",
      "action": "ec:EC-GenerateReport",
      "input": {
        "date": "{{today}}",
        "sources": ["rss", "github", "news"]
      },
      "retry_policy": {
        "max_retries": 3,
        "retry_delay": 60
      }
    },
    {
      "step_id": 2,
      "name": "撰写帖子草稿",
      "description": "基于报告撰写社交媒体帖子",
      "action": "ec:EC-DraftPost",
      "input": {
        "report_path": "{{steps.1.output.report_path}}",
        "template": "daily-post"
      },
      "depends_on": [1],
      "retry_policy": {
        "max_retries": 2
      }
    },
    {
      "step_id": 3,
      "name": "发布到 Moltbook",
      "description": "发布帖子到 Moltbook",
      "action": "ec:EC-PublishToMoltbook",
      "input": {
        "draft_path": "{{steps.2.output.draft_path}}",
        "submolt": "general"
      },
      "depends_on": [2]
    },
    {
      "step_id": 4,
      "name": "更新状态",
      "description": "更新 heartbeat 状态",
      "action": "ec:EC-UpdateStatus",
      "input": {
        "task": "daily_post",
        "status": "completed"
      },
      "depends_on": [3]
    }
  ]
}
